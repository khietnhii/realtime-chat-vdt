# Sao chép file này thành .env rồi điều chỉnh nếu cần
DATABASE_URL="postgresql://user:password@localhost:5432/chat_db?schema=public"
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET="doi-thanh-mot-chuoi-bi-mat-that-dai-ngau-nhien"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# Google Gemini API (dùng cho tính năng Catch Me Up / Tóm tắt AI)
# Lấy API Key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# SMTP Email (dùng cho tính năng gửi mã xác nhận OTP đăng ký)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

# Cloudinary (dùng để lưu trữ hình ảnh và file upload)
# Tạo tài khoản miễn phí tại: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
